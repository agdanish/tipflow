# Required: WDK seed phrase (generate with: node -e "const {WDK}=require('@tetherto/wdk');console.log(WDK.getRandomSeedPhrase())")
# SEED_PHRASE=your twelve word seed phrase here

# Optional: Ollama URL for AI features (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Optional: Telegram bot token for Telegram tipping
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Optional: ERC-4337 gasless transactions (requires Pimlico API key)
# ERC4337_BUNDLER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_KEY
# ERC4337_PAYMASTER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_KEY

# Optional: Custom Ethereum RPC for ENS resolution
# ETH_MAINNET_RPC=https://cloudflare-eth.com
