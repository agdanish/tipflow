# TipFlow Agent — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are OPTIONAL — the agent works with sensible defaults.

# WDK seed phrase (auto-generated if not provided)
# WDK_SEED=your twelve word seed phrase here

# Ollama LLM for AI features (falls back to regex NLP if unavailable)
# OLLAMA_HOST=http://localhost:11434

# Server port (default: 3001)
# PORT=3001

# Telegram bot token for Telegram tipping commands
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ERC-4337 gasless transactions (requires Pimlico API key)
# ERC4337_BUNDLER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_KEY
# ERC4337_PAYMASTER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_KEY

# Custom RPC endpoints (free public defaults are used if not set)
# ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# ETH_MAINNET_RPC=https://cloudflare-eth.com
