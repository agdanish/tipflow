# TipFlow Agent Configuration
# Copy this file to .env and fill in values

# WDK seed phrase (BIP-39 mnemonic) — KEEP SECRET
# Generate one with: node -e "import('@tetherto/wdk').then(m => console.log(m.default.getRandomSeedPhrase()))"
WDK_SEED=

# EVM RPC providers (free tier)
ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# TON testnet
TON_TESTNET_URL=https://testnet.toncenter.com/api/v2/jsonRPC

# Ollama (local AI)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# Server
PORT=3001
